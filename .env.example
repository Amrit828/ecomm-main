# Copy to .env and fill in for production deployments.
# These are passed to docker-compose at runtime.

# Required for auth JWT signing — change this to a long random string in prod
JWT_SECRET=supersecretkey123456789012345678

# Frontend API URLs — these are baked into the React build at build-time.
# When running locally with docker-compose, localhost works because the browser
# talks directly to the host ports (8081-8084).
# For a cloud deployment, replace localhost with your server's public IP/domain.
VITE_AUTH_URL=http://localhost:8081
VITE_PRODUCT_URL=http://localhost:8082
VITE_CART_URL=http://localhost:8083
VITE_ORDER_URL=http://localhost:8084
